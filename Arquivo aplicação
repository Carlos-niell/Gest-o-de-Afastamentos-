,p_process_sql_clob=>wwv_flow_string.join(wwv_flow_t_varchar2(
'DECLARE',
'    l_parameters  apex_workflow.t_workflow_parameters;',
'    l_id          NUMBER;',
'    l_workflow_id NUMBER; ',
'BEGIN',
'    FOR i IN 1..APEX_APPLICATION.G_F01.COUNT LOOP',
'        l_id := APEX_APPLICATION.G_F01(i);',
'        ',
'        l_parameters.DELETE;',
'',
'        FOR c1 IN (SELECT LOGIN_CHEFE, DATA_FIM, DATA_INICIO, LOGIN_SOLICITANTE, NOME_SOLICITANTE, TIPO_AFASTAMENTO',
'                     FROM TB_AFASTAMENTOS',
'                    WHERE ID = l_id) ',
'        LOOP',
'            l_parameters(1) := apex_workflow.t_workflow_parameter(static_id => ''LOGIN_CHEFE'',       string_value => c1.LOGIN_CHEFE);',
'            l_parameters(2) := apex_workflow.t_workflow_parameter(static_id => ''DATA_FIM'',            string_value => TO_CHAR(c1.DATA_FIM, ''DD/MM/YYYY''));',
'            l_parameters(3) := apex_workflow.t_workflow_parameter(static_id => ''DATA_INI'',            string_value => TO_CHAR(c1.DATA_INICIO, ''DD/MM/YYYY''));',
'            l_parameters(4) := apex_workflow.t_workflow_parameter(static_id => ''ID_SOLICITACAO'',      string_value => TO_CHAR(l_id));',
'            l_parameters(5) := apex_workflow.t_workflow_parameter(static_id => ''LOGIN_USUARIO'',       string_value => c1.LOGIN_SOLICITANTE);',
'            l_parameters(6) := apex_workflow.t_workflow_parameter(static_id => ''NOME_SOLICITANTE'', string_value => c1.NOME_SOLICITANTE);',
'            l_parameters(7) := apex_workflow.t_workflow_parameter(static_id => ''TIPO_AFASTAMENTO'',    string_value => c1.TIPO_AFASTAMENTO);',
'        END LOOP;',
'',
'        l_workflow_id := apex_workflow.start_workflow (',
'            p_static_id  => ''Afastamentos'',',
'            p_detail_pk  => TO_CHAR(l_id),',
'            p_parameters => l_parameters',
'        );',
'',
'        UPDATE TB_AFASTAMENTOS ',
'           SET STATUS = ''Aguardando Gestor'' ',
'         WHERE ID = l_id;',
'         ',
'    END LOOP;',
'END;'))
